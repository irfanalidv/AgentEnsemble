# AgentEnsemble - Copy to .env and add your keys
# Format: KEY=value (no spaces around =)
# Required for LLM agents (ReAct, Hybrid, Router, etc.)
MISTRAL_API_KEY=your-mistral-api-key

# Required for web search (Serper API). Without this, SearchTool falls back to DuckDuckGo.
SERPER_API_KEY=your-serper-api-key
